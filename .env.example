# LLM Configuration
# Supported providers: openai, anthropic
# The BAML client is configured in baml_src/clients.baml
# These keys are read by BAML at runtime via env vars
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Application settings
MAX_FILE_SIZE_MB=10
