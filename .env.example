# LLM Configuration
# Supported primary providers: openai, anthropic, google, xai
# The BAML fallback chain is: GPT-4o → Claude Sonnet → Gemini → Grok
# Only the key for your chosen provider is required; others are used as fallbacks
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
XAI_API_KEY=your-xai-api-key-here

# Primary LLM provider: "openai", "anthropic", "google", or "xai" (default: openai)
LLM_PRIMARY_PROVIDER=openai

# Application settings
MAX_FILE_SIZE_MB=10
