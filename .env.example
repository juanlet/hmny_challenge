# LLM Configuration
# Supported primary providers: openai, anthropic, google, xai
# LLM_PRIMARY_PROVIDER=auto  selects the first provider with a valid API key.
# Only the key for your chosen provider is required; others are tried as fallbacks.
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
XAI_API_KEY=your-xai-api-key-here

# Primary LLM provider: "auto", "openai", "anthropic", "google", or "xai" (default: auto)
LLM_PRIMARY_PROVIDER=auto

# Model names — optional, defaults shown. Override to pin a specific version.
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# GEMINI_MODEL=gemini-2.0-flash
# XAI_MODEL=grok-3

# Application settings
MAX_FILE_SIZE_MB=10
